  "keyFeatures": [
    "Query editor with Monaco-based syntax highlighting and autocompletion",
    "Virtual-scrolled data grid with inline cell editing",
    "Interactive schema browser with tree view",
    "Auto-generated ER diagrams for visualizing table relationships",
    "Import/export in CSV, JSON, SQL, and Excel formats",
    "Native backup and restore using pg_dump, mysqldump, etc.",
    "SSH tunneling and SSL/TLS encryption support",
    "Process monitoring for active database connections",
    "Command palette for quick action access",
    "Cross-platform support (macOS, Windows, Linux)"
  ],
  "publicApiSurface": [
    "PostgreSQL connection (versions 12+)",
    "MySQL connection (versions 5.7+)",
    "MariaDB connection (versions 10.4+)",
    "SQLite connection (bundled)",
    "DuckDB connection (bundled)",
    "ClickHouse connection (versions 22.8+)",
    "SQL Server connection (versions 2012+)",
    "MongoDB connection (versions 4.2+)",
    "Redis connection (versions 6.0+)",
    "SQL query execution",
    "Schema introspection API",
    "Data grid operations (CRUD)",
    "Import/Export operations",
    "Backup/Restore operations",
    "SSH tunnel establishment"
  ]
